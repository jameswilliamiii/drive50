<% content_for :title, "Sign In" %>

<div class="authentication-form-container">
  <%= form_with url: session_path, class: "drive-form" do |form| %>
    <%= render "shared/auth_header", title: "Welcome back", subtitle: "Sign in to keep logging your drives." %>

    <div class="field">
      <%= form.label :email_address, "Email Address" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
                           value: params[:email_address] %>
    </div>

    <%= render "shared/password_field", form: form, field: :password, label: "Password",
               autocomplete: "current-password" %>

    <div class="actions">
      <%= form.submit "Sign In", class: "button-primary" %>
      <%= link_to "Sign Up", new_registration_path, class: "button" %>
    </div>

    <div class="form-footer">
      <%= link_to "Forgot password?", new_password_path %>
    </div>
  <% end %>
</div>
