<%# locals: (form:, field:, label:, autocomplete: "current-password", hint: nil, autofocus: false, required: true) %>
<div class="field" data-controller="password-visibility">
  <%= form.label field, label %>
  <div class="password-field">
    <%= form.password_field field, required: required, autocomplete: autocomplete, maxlength: 72, autofocus: autofocus,
                            class: "password-input", data: { password_visibility_target: "input" } %>
    <button type="button" class="password-toggle" aria-label="Show password"
            data-action="password-visibility#toggle" data-password-visibility-target="button">
      <span data-password-visibility-target="show"><%= icon(:eye, size: 20) %></span>
      <span class="hidden" data-password-visibility-target="hide"><%= icon(:eye_off, size: 20) %></span>
    </button>
  </div>
  <% if hint %><small><%= hint %></small><% end %>
</div>
